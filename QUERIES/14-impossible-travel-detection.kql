// ============================================
// QUERY: Impossible Travel Detection
// MITRE ATT&CK: T1550 - Use Alternate Authentication Material
// SEVERITY: High
// AUTHOR: Luvuyo Prince Ntantiso
// DATE: July 2026
// ============================================

// Description:
// Detects impossible travel scenarios where a user authenticates from two
// geographically distant locations in an impossibly short time window.
// Indicates credential compromise or account takeover. A user cannot
// physically travel 1000+ miles in minutes. Legitimate scenarios are rare.

SigninLogs
| where TimeGenerated > ago(7d)
| where ResultType == 0  // Successful logins only
| extend
    UserAccount = UserPrincipalName,
    LoginCountry = LocationDetails.countryOrRegion,
    LoginCity = LocationDetails.city,
    LoginLatitude = LocationDetails.geoCoordinates.latitude,
    LoginLongitude = LocationDetails.geoCoordinates.longitude,
    SourceIP = IPAddress,
    AuthMethod = AuthenticationDetails[0].authenticationMethod,
    DeviceInfo = DeviceDetail.displayName
| where LoginCountry != ""  // Must have location data
| summarize
    LoginCount = count(),
    UniqueCountries = dcount(LoginCountry),
    UniqueCities = dcount(LoginCity),
    FirstLogin = min(TimeGenerated),
    LastLogin = max(TimeGenerated),
    Countries = make_set(LoginCountry),
    Cities = make_set(LoginCity),
    Latitudes = make_set(LoginLatitude),
    Longitudes = make_set(LoginLongitude),
    SourceIPs = make_set(SourceIP),
    DeviceNames = make_set(DeviceInfo)
    by UserAccount
| where UniqueCountries >= 2  // At least 2 different countries
| extend
    TimeDifferenceBetweenLogins = LastLogin - FirstLogin,
    TimeDifferenceMinutes = totimespan(TimeDifferenceBetweenLogins).TotalMinutes
| where TimeDifferenceMinutes <= 120  // Within 2 hours (120 minutes)
| extend
    // Approximate distance calculation (Haversine formula simplified)
    // This is a rough estimate - actual calculation would be more precise
    DistanceIndicator = case(
        UniqueCountries == 2 and TimeDifferenceMinutes <= 60, "Likely Impossible",
        UniqueCountries >= 3 and TimeDifferenceMinutes <= 120, "Highly Suspicious",
        "Suspicious"
    )
| project
    UserAccount = UserAccount,
    LoginCount = LoginCount,
    UniqueCountriesCount = UniqueCountries,
    UniqueCitiesCount = UniqueCities,
    CountriesDetected = Countries,
    CitiesDetected = Cities,
    SourceIPsDetected = SourceIPs,
    DevicesUsed = DeviceNames,
    TimeWindowMinutes = TimeDifferenceMinutes,
    FirstLoginTime = FirstLogin,
    LastLoginTime = LastLogin,
    ImpossibleTravelIndicator = DistanceIndicator,
    Severity = case(
        (DistanceIndicator == "Likely Impossible"), "Critical",
        (DistanceIndicator == "Highly Suspicious"), "High",
        "Medium"
    )
| sort by TimeWindowMinutes asc  // Shortest time window = most suspicious

