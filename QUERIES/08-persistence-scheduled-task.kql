// ============================================
// QUERY: Persistence - Scheduled Task Detection
// MITRE ATT&CK: T1053.005 - Scheduled Task/Job: Scheduled Task
// SEVERITY: High
// AUTHOR: Luvuyo Prince Ntantiso
// DATE: July 2026
// ============================================

// Description:
// Detects creation of suspicious scheduled tasks used for persistence.
// Attackers create scheduled tasks to execute malware, backdoors, or
// credential harvesters on a recurring basis. Indicators: unusual task names,
// suspicious command lines, tasks running as SYSTEM, created outside business hours.

SecurityEvent
| where TimeGenerated > ago(7d)
| where EventID in (
    4698,   // Scheduled task created
    4702,   // Scheduled task updated
    4699    // Scheduled task deleted (suspicious)
)
| extend
    TaskName = tolower(tostring(parse_json(EventData).TaskName)),
    TaskPath = tolower(tostring(parse_json(EventData).TaskContentNew)),
    CreatedBy = Account,
    CreatedByIP = IpAddress,
    Computer = Computer
| where 
    // Suspicious task names
    (TaskName contains "update" and TaskName contains "check") or
    (TaskName contains "system" and TaskName contains "maintenance") or
    (TaskName contains "windows" and (TaskName contains "system" or TaskName contains "temp")) or
    (TaskName contains "svchost" or TaskName contains "rundll32" or TaskName contains "powershell") or
    TaskName contains "scanner" or
    TaskName contains "checker" or
    TaskName contains "monitor" or
    TaskName contains "backup" or
    TaskName matches regex @"^[a-z0-9]{12,}$"  // Random strings
    or
    // Suspicious command patterns
    (TaskPath contains "powershell" and TaskPath contains "-enc") or
    (TaskPath contains "cmd" and TaskPath contains "/c") or
    (TaskPath contains "rundll32" and TaskPath contains "javascript") or
    (TaskPath contains "regsvr32" and TaskPath contains "/s") or
    (TaskPath contains "mshta" or TaskPath contains "wscript")
| summarize
    TaskCreationCount = count(),
    UniqueTasks = dcount(TaskName),
    SuspiciousTasks = make_set(TaskName),
    CommandPatterns = make_set(TaskPath),
    FirstTask = min(TimeGenerated),
    LastTask = max(TimeGenerated)
    by Computer, CreatedBy
| extend
    TimeDifference = LastTask - FirstTask
| where UniqueTasks >= 1  // Any suspicious task
| project
    ComputerName = Computer,
    CreatedByAccount = CreatedBy,
    SuspiciousTaskCount = TaskCreationCount,
    UniqueTaskCount = UniqueTasks,
    TaskNamesDetected = SuspiciousTasks,
    CommandPatternsDetected = CommandPatterns,
    TimeWindowHours = totimespan(TimeDifference).TotalHours,
    FirstTaskCreationTime = FirstTask,
    LastTaskCreationTime = LastTask,
    Severity = case(
        TaskCreationCount >= 3, "Critical",
        UniqueTasks >= 2, "High",
        TaskCreationCount >= 2, "High",
        "Medium"
    )
| sort by TaskCreationCount desc

