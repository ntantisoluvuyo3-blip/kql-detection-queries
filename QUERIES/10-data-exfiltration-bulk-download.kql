// ============================================
// QUERY: Data Exfiltration - Bulk Download Detection
// MITRE ATT&CK: T1537 - Transfer Data to Cloud Account
// SEVERITY: High
// AUTHOR: Luvuyo Prince Ntantiso
// DATE: July 2026
// ============================================

// Description:
// Detects bulk file downloads that may indicate data exfiltration.
// Attackers download sensitive files before uploading to cloud storage
// or external servers. Indicators: multiple large downloads, rapid download
// speed, downloads of archives/sensitive file types, unusual destinations.

SecurityEvent
| where TimeGenerated > ago(24h)
| where EventID == 5145  // Network share object accessed
    or EventID == 5140   // Network share accessed
| extend
    AccessedShare = tolower(tostring(parse_json(EventData).ShareName)),
    RelativeTarget = tolower(tostring(parse_json(EventData).RelativeTargetName)),
    AccessRequest = tolower(tostring(parse_json(EventData).AccessRequest)),
    User = Account,
    Computer = Computer,
    SourceIP = IpAddress
| where AccessRequest contains "ReadData" or AccessRequest contains "ReadAttributes"
| where 
    // Sensitive file types
    (RelativeTarget endswith ".xlsx" or RelativeTarget endswith ".docx" or
     RelativeTarget endswith ".pptx" or RelativeTarget endswith ".pdf" or
     RelativeTarget endswith ".zip" or RelativeTarget endswith ".rar" or
     RelativeTarget endswith ".7z" or RelativeTarget endswith ".csv" or
     RelativeTarget endswith ".json" or RelativeTarget endswith ".sql" or
     RelativeTarget endswith ".mdb" or RelativeTarget endswith ".db")
    or
    // Sensitive locations
    (AccessedShare contains "finance" or AccessedShare contains "hr" or
     AccessedShare contains "legal" or AccessedShare contains "confidential" or
     AccessedShare contains "secret" or AccessedShare contains "backup" or
     AccessedShare contains "database" or AccessedShare contains "archive")
| summarize
    FileAccessCount = count(),
    UniqueFiles = dcount(RelativeTarget),
    FilesAccessed = make_set(RelativeTarget),
    FirstAccess = min(TimeGenerated),
    LastAccess = max(TimeGenerated)
    by Computer, User, SourceIP
| extend
    TimeDifference = LastAccess - FirstAccess,
    FilesPerMinute = FileAccessCount / (totimespan(TimeDifference).TotalMinutes + 1)
| where FileAccessCount >= 5  // 5+ files accessed
| project
    ComputerName = Computer,
    UserAccount = User,
    SourceIPAddress = SourceIP,
    FileAccessCount = FileAccessCount,
    UniqueFilesAccessed = UniqueFiles,
    SensitiveFilesDetected = FilesAccessed,
    TimeWindowMinutes = totimespan(TimeDifference).TotalMinutes,
    FilesAccessedPerMinute = FilesPerMinute,
    FirstAccessTime = FirstAccess,
    LastAccessTime = LastAccess,
    Severity = case(
        FileAccessCount >= 20, "Critical",
        FileAccessCount >= 10, "High",
        FilesPerMinute >= 2, "High",
        "Medium"
    )
| sort by FileAccessCount desc

// ALTERNATIVE: Detect cloud upload activity after file access
// Uncomment to use this version instead:
